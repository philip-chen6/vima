FROM python:3.12-slim

WORKDIR /app

COPY packages/vima-mcp/pyproject.toml ./packages/vima-mcp/pyproject.toml
COPY packages/vima-mcp/README.md ./packages/vima-mcp/README.md
COPY packages/vima-mcp/src ./packages/vima-mcp/src

RUN pip install --no-cache-dir ./packages/vima-mcp

ENV VIMA_MCP_HOST=0.0.0.0
ENV PYTHONUNBUFFERED=1

EXPOSE 8766
CMD ["sh", "-c", "VIMA_MCP_PORT=${PORT:-8766} vima-mcp"]
