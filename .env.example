# vima environment template — copy to .env and fill in
# .env is gitignored. on prod, this lives at /opt/vima/.env

# ── anthropic claude vision (CII judge) ─────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── public domain (set once .tech domain points at the vps) ─────────────────
VIMA_DOMAIN="vimaspatial.tech"

# ── frontend build-time vars (next.js bakes NEXT_PUBLIC_* into the bundle) ──
# leave empty to use same-origin /api/* (recommended in prod behind caddy)
NEXT_PUBLIC_BACKEND_URL=""

# absolute URL of the production site (used for opengraph + canonical tags).
NEXT_PUBLIC_SITE_URL="https://vimaspatial.tech"
