.env
# top-level data/ is for project-local artifacts (memory dumps, etc).
# Anchored so it doesn't clobber frontend/public/data/ which holds real
# shipping assets (cameras.json, episodes.json, depth-filter-log.json).
/data/
artifacts/
__pycache__/
*.pyc
tools/yolodex/runs/
tools/yolodex/output/
*.aux
*.bbl
*.blg
*.log
*.out
missfont.log
.DS_Store
.gstack/
